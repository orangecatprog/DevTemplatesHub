{
    "name": "devtemplates-hub",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "prepare": "husky",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/css": "^1.4.0",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^2.0.1",
        "@eslint/markdown": "^8.0.3",
        "@types/bun": "latest",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.0",
        "prettier": "^3.9.6",
        "typescript-eslint": "^8.65.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "lint-staged": {
        "*.{ts,tsx,js,mjs,cjs,json,yml,yaml,md}": [
            "prettier --write"
        ],
        "*.{ts,tsx,js,mjs,cjs}": [
            "eslint --fix"
        ]
    }
}
