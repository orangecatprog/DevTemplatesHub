# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Source code
*.ts text
*.tsx text
*.js text
*.mjs text
*.cjs text
*.json text
*.jsonc text
*.md text
*.yml text
*.yaml text
*.toml text
*.css text
*.scss text
*.html text
*.svg text
*.xml text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
